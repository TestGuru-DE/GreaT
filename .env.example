# G.R.E.A.T. Konfiguration
# Kopiere diese Datei nach .env und passe Werte an.
# Commit diese Datei (als .env.example) ins Repo, nicht .env selbst!

# Backend-Port (default: 8000)
# Nutze z.B. GREAT_PORT=9000 vor Start.bat/Start.sh
GREAT_PORT=8000

# Backend-Host (default: 0.0.0.0 = alle Interfaces)
# Ändere zu "127.0.0.1" wenn nur lokal erreichbar sein soll
GREAT_HOST=0.0.0.0

# Datenbank (default: SQLite lokal)
# Für lokale Entwicklung (Standard):
# DATABASE_URL=sqlite:///./great.db

# Für PostgreSQL (Produktion):
# DATABASE_URL=postgresql://user:password@localhost/great

# Für MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost/great
